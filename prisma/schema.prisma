// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Goal {
  maintain
  cut
  bulk
}

enum ActivityLevel {
  sedentary
  light
  moderate
  active
  very_active
}

enum PortionComfortLevel {
  low
  medium
  high
}

enum PlanStatus {
  draft
  locked
}

enum MealSlot {
  breakfast
  lunch
  dinner
  snack
}

enum SourceType {
  tick
  photo
  manual
}

enum ComparisonResult {
  match
  less
  more
  different
}

model User {
  id                 String             @id @default(cuid())
  email              String             @unique
  passwordHash       String
  age                Int?
  sexGender          String?
  heightCm           Float?
  weightKg           Float?
  activityLevel      ActivityLevel?
  goal               Goal?
  preferences        String?
  allergies          String?
  dislikes           String?
  edHistoryFlag      Boolean            @default(false)
  edTriggerNotes     String?
  portionComfort     PortionComfortLevel?
  calorieTarget      Int?
  macroProteinTarget Int?
  macroCarbTarget    Int?
  macroFatTarget     Int?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  dailyPlans         DailyPlan[]
  mealLogs           MealLog[]
  adjustments        Adjustment[]
}

model DailyPlan {
  id                  String       @id @default(cuid())
  userId              String
  date                DateTime
  status              PlanStatus   @default(draft)
  totalTargetCalories Int
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  user                User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  plannedMeals        PlannedMeal[]

  @@unique([userId, date])
}

model PlannedMeal {
  id              String      @id @default(cuid())
  dailyPlanId     String
  date            DateTime
  mealSlot        MealSlot
  mealName        String
  portionText     String
  plannedCalories Int
  plannedProtein  Int
  plannedCarbs    Int
  plannedFat      Int
  locked          Boolean     @default(false)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  dailyPlan       DailyPlan   @relation(fields: [dailyPlanId], references: [id], onDelete: Cascade)
  mealLogs        MealLog[]

  @@unique([dailyPlanId, mealSlot])
}

model MealLog {
  id               String           @id @default(cuid())
  userId           String
  plannedMealId    String
  date             DateTime
  mealSlot         MealSlot
  sourceType       SourceType
  actualCalories   Int
  actualProtein    Int
  actualCarbs      Int
  actualFat        Int
  comparisonResult ComparisonResult
  confidence       Float?
  note             String?
  createdAt        DateTime         @default(now())
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  plannedMeal      PlannedMeal      @relation(fields: [plannedMealId], references: [id], onDelete: Cascade)
  adjustment       Adjustment?

  @@index([userId, date])
}

model Adjustment {
  id                   String   @id @default(cuid())
  userId               String
  date                 DateTime
  triggeredByMealLogId String   @unique
  summaryText          String
  calorieDelta         Int
  macroDeltaJson       String
  appliedToMealsJson   String
  acceptedFlag         Boolean  @default(true)
  createdAt            DateTime @default(now())
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  triggeredByMealLog   MealLog  @relation(fields: [triggeredByMealLogId], references: [id], onDelete: Cascade)

  @@index([userId, date])
}
